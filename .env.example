# Environment Configuration for Electricity Price Prediction
# Copy this file to .env and adjust the values as needed

# Data File Path
# Default: ./electricity.csv (relative to project root)
# You can use absolute or relative paths
# Examples:
#   DATA_PATH=./electricity.csv
#   DATA_PATH=/path/to/your/electricity.csv
#   DATA_PATH=C:\Users\YourName\data\electricity.csv
DATA_PATH=./electricity.csv
