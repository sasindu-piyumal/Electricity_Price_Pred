# ============================================================================
# Electricity Price Prediction - Configuration Template
# ============================================================================
# Copy this file to .env and update the values according to your environment
# DO NOT commit .env file with actual values to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Data Configuration
# ----------------------------------------------------------------------------

# Path to the electricity dataset CSV file
# This should point to the electricity.csv file containing the training data
# Default: ./electricity.csv (relative to project root)
# Example: /path/to/data/electricity.csv
DATA_FILE_PATH=./electricity.csv

# ----------------------------------------------------------------------------
# Output Configuration
# ----------------------------------------------------------------------------

# Directory path where plots, results, and model outputs will be saved
# The directory will be created if it doesn't exist
# Default: ./output
# Example: /path/to/output
OUTPUT_DIR=./output

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------

# Logging verbosity level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Detailed information for diagnosing problems
# INFO: General informational messages about program execution
# WARNING: Warning messages for potential issues
# ERROR: Error messages for serious problems
# CRITICAL: Critical messages for very serious errors
# Default: INFO
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Validation Configuration
# ----------------------------------------------------------------------------

# Maximum allowed CSV file size in megabytes (MB)
# This is used to validate the input data file size before processing
# Set to 0 to disable file size validation
# Default: 500
# Example: 1000 (for 1GB limit)
MAX_FILE_SIZE_MB=500

# ----------------------------------------------------------------------------
# Environment Configuration
# ----------------------------------------------------------------------------

# Environment indicator for the application
# Options: DEV, PROD
# DEV: Development environment (may enable debug features, verbose logging)
# PROD: Production environment (optimized performance, reduced logging)
# Default: DEV
ENVIRONMENT=DEV
